        "<LEADER>gt": ["choose-theme"],
        "<LEADER>gf": ["choose-file"],
        "<LEADER>go": ["choose-open"],
        "<LEADER>gd": ["choose-open-document"],
        "<LEADER>gl": [".fuzzy-search-lines"],
