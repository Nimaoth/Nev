    "terminal.normal": {
        "<ESCAPE>": ["terminal.set-terminal-mode", "normal"],
        "i": ["terminal.set-terminal-mode", "insert"],
        "a": ["all", ["terminal.set-terminal-mode", "insert"], ["terminal.send-terminal-input", "<RIGHT>"]],
        "I": ["all", ["terminal.set-terminal-mode", "insert"], ["terminal.send-terminal-input", "<HOME>"]],
        "A": ["all", ["terminal.set-terminal-mode", "insert"], ["terminal.send-terminal-input", "<END>"]],
        "<C-c>": ["terminal.send-terminal-input", "<C-c>", true],
        "<ENTER>": ["terminal.send-terminal-input", "<ENTER>"],
        "<UP>": ["terminal.send-terminal-input", "<UP>"],
        "<DOWN>": ["terminal.send-terminal-input", "<DOWN>"],
        "<LEFT>": ["terminal.send-terminal-input", "<LEFT>"],
        "<RIGHT>": ["terminal.send-terminal-input", "<RIGHT>"],
        "<HOME>": ["terminal.send-terminal-input", "<HOME>"],
        "<END>": ["terminal.send-terminal-input", "<END>"],
        "<C-e>": ["terminal.edit-terminal-buffer"],
        "<C-u>": "terminal.scroll 50",
        "<C-d>": "terminal.scroll -50",
        "<C-v>": "terminal.paste",
        "p": "terminal.paste",
    },
    "terminal": {
        "<CS-UP>": "terminal.scroll 2",
        "<CS-DOWN>": "terminal.scroll -2",
        "<CS-PAGE_UP>": "terminal.scroll 50",
        "<CS-PAGE_DOWN>": "terminal.scroll -50",
        "<CS-HOME>": "terminal.scroll 500000",
        "<CS-END>": "terminal.scroll -500000",
        "gg": "terminal.scroll 500000",
        "G": "terminal.scroll -500000",
    },
    "terminal.insert": {
        "cf": ["terminal.set-terminal-mode", "normal"],
        "<C-ENTER>": ["terminal.send-terminal-input-and-set-mode", "<ENTER>", "normal"],
    },

    "#count": {
      "<-1-9><o-0-9>": [""],
    },

    "vim#text_object": {
        "<?-count>iw": ["(count* <#text_object.count>) (vim.word-inner) (inclusive)"],
        "<?-count>aw": ["(count* <#text_object.count>) (vim.word-inner) (inclusive)"],
        "<?-count>iW": ["(count* <#text_object.count>) (vim.WORD-inner) (inclusive)"],
        "<?-count>aW": ["(count* <#text_object.count>) (vim.WORD-inner) (inclusive)"],
        "ip": ["(vim.paragraph-inner) (inclusive)"],
        "ap": ["(vim.paragraph-outer) (inclusive)"],
        "ia": ["(ts 'call.inner') (overlapping) (last) (grow -1) (inclusive)"],
        "aa": ["(ts 'call.inner') (overlapping) (last) (inclusive)"],
        "ic": ["(ts 'call.outer') (overlapping) (last) (inclusive)"],
        "ie": ["(ts 'parameter.inner') (overlapping) (last) (inclusive)"],
        "ae": ["(ts 'parameter.inner') (overlapping) (last) (inclusive)"],

        "i{": ["(surround \"{\" \"}\" true)"],
        "a{": ["(surround \"{\" \"}\" false)"],
        "i}": ["(surround \"{\" \"}\" true)"],
        "a}": ["(surround \"{\" \"}\" false)"],
        "i(": ["(surround \"(\" \")\" true)"],
        "a(": ["(surround \"(\" \")\" false)"],
        "i)": ["(surround \"(\" \")\" true)"],
        "a)": ["(surround \"(\" \")\" false)"],
        "i[": ["(surround \"[\" \"]\" true)"],
        "a[": ["(surround \"[\" \"]\" false)"],
        "i]": ["(surround \"[\" \"]\" true)"],
        "a]": ["(surround \"[\" \"]\" false)"],
        "i\\<": ["(surround \"<\" \">\" true)"],
        "a\\<": ["(surround \"<\" \">\" false)"],
        "i\\>": ["(surround \"<\" \">\" true)"],
        "a\\>": ["(surround \"<\" \">\" false)"],
        "i\"": ["(surround \"\\\"\" \"\\\"\" true)"],
        "a\"": ["(surround \"\\\"\" \"\\\"\" false)"],
        "i'": ["(surround \"'\" \"'\" true)"],
        "a'": ["(surround \"'\" \"'\" false)"],
    },

    "vim.visual-line#move": {
        "<?-count><UP>": ["vim.move-direction \"line-up\" <#move.count>"],
        "<?-count><DOWN>": ["vim.move-direction \"line-down\" <#move.count>"],
        "<?-count>k": ["vim.move-direction \"line-up\" <#move.count>"],
        "<?-count>j": ["vim.move-direction \"line-down\" <#move.count>"],
    },

    "vim#move": {
        "<?-count><LEFT>": ["(count* <#move.count>) (column -1) ;exclusive"],
        "<?-count><RIGHT>": ["(count* <#move.count>) (column 1) ;exclusive"],
        "<?-count><UP>": ["(count* <#move.count>) (visual-line-up) ;dont-update-target-column"],
        "<?-count><DOWN>": ["(count* <#move.count>) (visual-line-down) ;dont-update-target-column"],
        "<?-count>h": ["(count* <#move.count>) (column -1) ;exclusive"],
        "<?-count>l": ["(count* <#move.count>) (column 1) ;exclusive"],
        "<?-count>k": ["(count* <#move.count>) (visual-line-up) ;dont-update-target-column"],
        "<?-count>j": ["(count* <#move.count>) (visual-line-down) ;dont-update-target-column"],
        "gM": ["move-cursor-line-center"], // todo
        "gm": ["move-cursor-center"], // todo
        "<?-count>n": ["(next-search-result (or <#move.count> 1)) (start)"],
        "<?-count>N": ["(prev-search-result (or <#move.count> 1)) (start)"],
        "<?-count>gf": ["(next-change (or <#move.count> 1)) (start)"],
        "<?-count>gh": ["(prev-change (or <#move.count> 1)) (start)"],
        "<?-count>gt": ["(next-diagnostic (or <#move.count> 1)) (start)"],
        "<?-count>gn": ["(prev-diagnostic (or <#move.count> 1)) (start)"],

        "0": ["(line) (start)"],
        "<HOME>": ["(visual-line) (start)"],
        "^": ["(line-no-indent) (start)"],
        "<?-count>$": ["(line (or <#move.count> 1)) (end)"],
        "<?-count><END>": ["(visual-line (or <#move.count> 1)) (end)"],
        "g0": ["(line) (start)"],
        "g^": ["(line-no-indent) (start)"],
        "<?-count>g$": ["(visual-line (or <#move.count> 1)) (end)"],
        "<?-count>gg": ["(let c <#move.count>) (if (eq c 0) (start (file)) (start (line-no-indent (line-num (- c 1)))))"],
        "<?-count>G": ["(file) (end) (line) (start) (if same? (end (line)))"],
        "<?-count>%": ["(let c <#move.count>) (if (eq c 0) (surround) (start (line-no-indent (line-num (floor (* num-lines (/ c 100)))))))"],

        "<?-count>w": "vim.move-selection-next \"(vim.word) (inclusive) ;exclusive\" false true <#move.count>",
        "<?-count><S-RIGHT>": "vim.move-selection-next \"(vim.word) (inclusive) ;exclusive\" false true <#move.count>",
        "<?-count>W": "vim.move-selection-next \"(vim.WORD) (inclusive) ;exclusive\" false true <#move.count>",
        "<?-count><C-RIGHT>": "vim.move-selection-next \"(vim.WORD) (inclusive) ;exclusive\" false true <#move.count>",
        "<?-count>e": "vim.move-selection-end \"(vim.word) (inclusive)\" false false <#move.count>",
        "<?-count>E": "vim.move-selection-end \"(vim.WORD) (inclusive)\" false false <#move.count>",
        "<?-count>b": "vim.move-selection-end \"(vim.word) (inclusive) ;exclusive\" true true <#move.count>",
        "<?-count><S-LEFT>": "vim.move-selection-end \"(vim.word) (inclusive) ;exclusive\" true true <#move.count>",
        "<?-count>B": "vim.move-selection-end \"(vim.WORD) (inclusive) ;exclusive\" true true <#move.count>",
        "<?-count><C-LEFT>": "vim.move-selection-end \"(vim.WORD) (inclusive) ;exclusive\" true true <#move.count>",
        "<?-count>ge": "vim.move-selection-next \"(vim.word) (inclusive)\" true false <#move.count>",
        "<?-count>gE": "vim.move-selection-next \"(vim.WORD) (inclusive)\" true false <#move.count>",
        "<?-count>}": "vim.move-paragraph false <#move.count>",
        "<?-count>{": "vim.move-paragraph true <#move.count> ;exclusive",
        "<?-count>f<CHAR>": ["(move-to <move.CHAR>)"],
        "<?-count>t<CHAR>": ["(column) (move-to <move.CHAR>) (column -1)"],
        "<?-count>f<SPACE>": ["(move-to \" \")"],
        "<?-count>t<SPACE>": ["(column) (move-to \" \") (column -1)"],
        "<?-count>f<ENTER>": ["(move-to \"\n\")"],
        "<?-count>t<ENTER>": ["(column) (move-to \"\n\") (column -1)"],

        "<?-count><C-d>": "vim.move-cursor-visual-page 30 <#move.count> true",
        "<?-count><PAGE_DOWN>": "vim.move-cursor-visual-page 100 <#move.count> true",
        "<?-count><C-u>": "vim.move-cursor-visual-page -30 <#move.count> true",
        "<?-count><PAGE_UP>": "vim.move-cursor-visual-page -100 <#move.count> true",
        "<?-count>|": "vim.move-to-column <#move.count>",
        "<?-count>-": "vim.move-cursor-line-first-char -1 <#move.count>",
        "<?-count>+": "vim.move-cursor-line-first-char 1 <#move.count>",
        "<?-count>_": "vim.move-to-start-of-line <#move.count>",
    },

    "vim.base": {
        ":": ["command-line"],

