        "<ESCAPE>": ["vim.exit-popup"],
        "<UP>": ["prev"],
        "<C-p>": ["prev"],
        "<DOWN>": ["next"],
        "<C-n>": ["next"],
        "<C-u>": ["prev", 5],
        "<C-d>": ["next", 5],
        "<C-b>": ["toggle-preview"],
