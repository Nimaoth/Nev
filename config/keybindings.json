        "M": ["enter-choose-cursor-mode", "vim.handle-select-word"],

        // movement
        "<C-r>": ["vim.select-prev"],
        "<C-m>": ["vim.select-next"],
        "<move>": ["vim.select-last <move>"],
        "<C-g>o": ["move", "(reverse)"],
        "<C-l>": ["move", "(next-tab-stop)"],
        "<C-v>": ["move", "(prev-tab-stop)"],
        "gu": ["move", "(align)", true, {"include-eol": false}],
        "gb": ["move", "(remove-empty)"],

        // copy/paste
        "p": ["vim.paste", true, false, "vim.default-register"],
