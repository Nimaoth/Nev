        "gc": ["toggle-line-comment"],
        "*": ["vim.set-search-query-from-word"],

        ".": ["replay-commands", "."],
        "L": ["vim.select-word-or-add-cursor"],
        "H": ["vim.move-last-selection-to-next-search-result"],

        "m<CHAR>": ["vim.add-mark <CHAR>"],
