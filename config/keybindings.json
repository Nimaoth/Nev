        "<LEADER>gn": ["open-last-view"],
        "<LEADER>fl": ["load-file"],
        "<LEADER>fs": ["write-file"],
        "<LEADER>gP": ["show-plugins"],
        "<LEADER>gL": ["lsp.list"],

