        "<LEADER>ae": ["edit-breakpoints"],
        "<LEADER>am": ["toggle-breakpoints-enabled"],
        "<LEADER>al": { "command": "run-last-configuration", "description": "Run last configuration" },
        "<LEADER>av": { "command": ["choose-run-configuration"], "description": "Choose run configuration" },
        "<LEADER>ab": { "command": ["toggle-breakpoint"], "description": "Toggle breakpoint" },

        "<LEADER>g": { "description": "Global pickers" },
        "<LEADER>a": { "description": "Debugger" },
        "<LEADER>o": { "description": "Options" },
        "<LEADER>w": { "description": "Window" },
        "<LEADER>wf": { "description": "Change font size" },
        "<LEADER>wk": { "description": "Split size ratio" },
        "<LEADER>r": { "description": "Run" },
        "<LEADER>f": { "description": "File" },

