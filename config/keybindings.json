        "<LEADER>w<*-f>-": ["change-font-size", -1],
        "<LEADER>w<*-f>+": ["change-font-size", 1],
        "<LEADER>wx": ["hide-active-view"],
        "<LEADER>wh": ["focus-view-left"],
