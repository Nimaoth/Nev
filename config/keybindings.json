    "vim.command-line-result-low": {
        "<ESCAPE>": "vim.exit-command-line",
    },

    "editor": {
        "<C-x><C-x>": "quit",
        "<ESCAPE>": "escape",
        "<SPACE>sr": "open-recent-session",
        "<SPACE>to": ["terminal.select"],
        "<SPACE>ts": [
            "terminal.run",
            "default",
            "",
            {
                "mode": "insert",
                "closeOnTerminate": true,
                "group": "scratch",
            }
        ],

